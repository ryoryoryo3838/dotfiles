# !/bin/bash

# exit immediately
set -e

# git
echo "Checking your current shell status..."
if [ $(command -v git) ]; then
	echo "git is already installed"
else
	echo "git is not installed. Installing git..."
	# check apt
	if [ ! $(command -v apt) ]; then
		echo "This is not a Debian-based system. Please install git and build-essential manually."
		exit 1
	fi
	sudo apt update
	sudo apt install -y git build-essential git
fi

# brew
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
if [ $(command -v brew) ]; then
	echo "Homebrew  is already installed"
else
	echo "Homebrew is not installed. Installing Homebrew..."
	/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
	if [ grep -q 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' $HOME/.bashrc ]; then
		echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' >> $HOME/.bashrc
	fi
	eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi


# install packages in Brewfile with Homebrew
cd $HOME/dotfiles
brew bundle

# setting zsh

# check stow files

echo "making bakup..."
mkdir -p $HOME/.init_bak

# なんかmvがsymlinkされてるフォルダだとうまくいかず

# .oh-my-zsh
if [ -d "$HOME/.oh-my-zsh" ]; then
	echo "oh-my-zsh already exist"
	#mv $HOME/.oh-my-zsh/ $HOME/.oh-my-zsh_bak
fi
# .zshrc
if [ -d "$HOME/.zshrc" ]; then
	echo ".zshrc already exist"
	echo "moving current .zshrc to .zshrc_bak"
	mv $HOME/.zshrc $HOME/.init_bak/.zshrc_bak
	mv $HOME/.zprofile $HOME/.init_bak/.zprofile_bak
	mv $HOME/.zsh_history $HOME/.init_bak/.zsh_history_bak
fi

# .gticonfig
if [ -d "$HOME/.gitconfig" ]; then
	echo ".gitconfig already exist"
	echo "moving current .gitconfig to .gitconfig_bak"
	mv $HOME/.gitconfig $HOME/.init_bak/.gitconfig_bak
fi

# .nvim
if [ -d "$HOME/.config/nvim" ]; then
	echo ".config/nvim already exist"
	echo "moving current .config/nvim to .config/nvim_bak"
	#mv $HOME/.config/nvim/ $HOME/.init_bak/nvim_bak
	mkdir -p $HOME/.config/nvim
else
	mkdir -p $HOME/.config/nvim
fi

# set symlink
stow -d $HOME/dotfiles/ -t $HOME/ zsh 
stow -d $HOME/dotfiles/ -t $HOME/ git
stow -d $HOME/dotfiles/ -t $HOME/.config/nvim nvim
# stow -d $HOME/dotfiles/ -t $HOME/ bash

Shell=${SHELL##*/}
echo "Restart your shell!"
echo "Run source .${Shell}rc"
